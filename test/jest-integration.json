{
  "rootDir": "..",
  "moduleFileExtensions": ["js", "json", "ts"],
  "testRegex": "test/.*\\.integration-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "<rootDir>/test/tsconfig.json" }]
  },
  "moduleNameMapper": {
    "^@/common/id-generator$": "<rootDir>/test/support/id-generator.fake.ts",
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "testEnvironment": "node",
  "testTimeout": 60000
}
